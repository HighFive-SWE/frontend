# ─────────────────────────────────────────────────────────────────────────────
# HighFive — frontend .env.example
#
# next.js reads .env.local for local development. copy this file to
# `.env.local` and fill in values for your environment.
#
# vars prefixed `NEXT_PUBLIC_` are inlined into the client bundle at build
# time — never put secrets in a NEXT_PUBLIC_* var.
# ─────────────────────────────────────────────────────────────────────────────


# api base url the browser will call. must be reachable from the browser, not
# only from inside a docker network. leave unset to fall back to
# http://localhost:8000 (services/api.ts:168).
NEXT_PUBLIC_API_URL=http://localhost:8000


# === optional / future =======================================================

# posthog (or other analytics) public key. only enable in staging / prod.
# NEXT_PUBLIC_POSTHOG_KEY=

# posthog host (defaults to https://us.posthog.com if unset).
# NEXT_PUBLIC_POSTHOG_HOST=

# sentry dsn for browser error reporting (optional).
# NEXT_PUBLIC_SENTRY_DSN=

# feature flags — flip to "1" to opt-in. document any flag you add here so
# the team can find them.
# NEXT_PUBLIC_FEATURE_GAMES=
# NEXT_PUBLIC_FEATURE_VOICE=
